---
import type { Dict } from "../i18n";
interface Props { dict: Dict; }
const { dict } = Astro.props;
const d = dict.guardianSight;
---

<section class="s-sight" id="guardian-sight" aria-labelledby="sight-heading">
  <div class="sight-layout wrap">
    <!-- AR rings visual -->
    <div
      class="sight-visual reveal"
      aria-label={d.ariaVisual}
    >
      <div class="gs-rings" aria-hidden="true">
        <div class="gs-ring gs-ring-a"></div>
        <div class="gs-ring gs-ring-b"></div>
        <div class="gs-ring gs-ring-c"></div>
        <div class="gs-center">
          <span class="gs-icon">◎</span>
        </div>
      </div>
      <div class="gs-tag gs-tag-a" aria-hidden="true">{d.floatTag1}</div>
      <div class="gs-tag gs-tag-b" aria-hidden="true">{d.floatTag2}</div>
    </div>

    <!-- Power copy -->
    <div class="sight-copy reveal reveal-d2">
      <p class="eyebrow">{d.eyebrow}</p>
      <h2 id="sight-heading" style="white-space:pre-line">{d.heading}</h2>
      <p class="sight-body" style="white-space:pre-line">{d.sightBody}</p>
      <p class="sight-note">{d.sightNote}</p>
    </div>
  </div>
</section>
