---
import type { Dict } from "../i18n";

interface Props { dict: Dict; lang: string; }
const { dict, lang } = Astro.props;
const f = dict.footer;
---

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-main">
      <div class="footer-brand">
        <a class="header-brand" href={`/${lang}`} aria-label={dict.ariaTop}>
          <img class="brand-logo" src="/ub_logo_svg.png" alt="" aria-hidden="true" />
        </a>
        <p class="footer-tagline">{f.tagline}</p>
      </div>

      {f.groups.map((g) => (
        <div class="footer-group">
          <h4>{g.label}</h4>
          {g.links.map((l) => (
            <a href={l.href.startsWith("mailto:") ? l.href : `/${lang}${l.href}`}>{l.label}</a>
          ))}
        </div>
      ))}
    </div>

    <hr class="footer-divider" />

    <div class="footer-bottom">
      <span class="footer-copy">{f.copyright}</span>
      <nav class="footer-legal" aria-label={dict.ariaLangNav}>
        {f.legal.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>
    </div>

    <p class="footer-credit">Built with ♥ in Bulgaria · Platform Engineering by <strong>DevOpsio</strong></p>
  </div>
</footer>
