---
import type { Dict } from "../i18n";

interface Props { dict: Dict; lang: string; }
const { dict, lang } = Astro.props;
const f = dict.footer;
---

<footer class="site-footer">
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <a class="header-brand" href={`/${lang}`} aria-label={dict.ariaTop}>
        <img class="brand-logo" src="/logo-full.png" alt="" aria-hidden="true" />
      </a>
      <p class="footer-tagline">{f.tagline}</p>
    </div>

    <nav class="footer-links" aria-label={dict.ariaFooterNav}>
      {f.groups.map((g) => (
        <div class="footer-group">
          <h4>{g.label}</h4>
          {g.links.map((l) => (
            <a href={l.href.startsWith("mailto:") ? l.href : `/${lang}${l.href}`}>{l.label}</a>
          ))}
        </div>
      ))}
    </nav>

    <div class="footer-legal">
      <p>{f.copyright}</p>
      <nav class="footer-legal-links" aria-label={dict.ariaLangNav}>
        {f.legal.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>
    </div>
  </div>

  <div class="footer-colophon">
    <div class="wrap">
      <span class="footer-colophon-heart">Built with ❤️ in Bulgaria</span>
      <span class="footer-colophon-credit">Platform Engineering &amp; Cloud Infrastructure by <strong>DevOpsio</strong></span>
    </div>
  </div>
</footer>
