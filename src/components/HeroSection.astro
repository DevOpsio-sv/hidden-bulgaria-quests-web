---
import type { Dict } from "../i18n";
interface Props { dict: Dict; lang: string; }
const { dict, lang } = Astro.props;
const h = dict.hero;
const a = dict.arrival;
---

<section class="arrival-section" aria-label={dict.ariaHero}>
  <!-- Animated globe -->
  <div class="globe-container" aria-hidden="true">
    <svg
      id="globe-svg"
      class="globe-svg"
      viewBox="0 0 500 500"
      xmlns="http://www.w3.org/2000/svg"
      role="presentation"
    >
      <defs>
        <radialGradient id="rg-atmos" cx="50%" cy="50%" r="50%">
          <stop offset="65%" stop-color="#030610" stop-opacity="0"/>
          <stop offset="100%" stop-color="#d8b56a" stop-opacity="0.2"/>
        </radialGradient>
        <radialGradient id="rg-surface" cx="34%" cy="32%" r="60%">
          <stop offset="0%" stop-color="#0c1929"/>
          <stop offset="100%" stop-color="#030814"/>
        </radialGradient>
        <radialGradient id="rg-glow" cx="34%" cy="32%" r="55%">
          <stop offset="0%" stop-color="#d8b56a" stop-opacity="0.06"/>
          <stop offset="100%" stop-color="#d8b56a" stop-opacity="0"/>
        </radialGradient>
        <clipPath id="globe-clip">
          <circle cx="250" cy="250" r="190"/>
        </clipPath>
      </defs>

      <!-- Outer atmosphere halo -->
      <circle cx="250" cy="250" r="226" fill="url(#rg-atmos)"/>

      <!-- Planet surface -->
      <circle cx="250" cy="250" r="190" fill="url(#rg-surface)"/>
      <circle cx="250" cy="250" r="190" fill="url(#rg-glow)"/>

      <!-- Grid lines — rotated on scroll by JS -->
      <g id="globe-grid" clip-path="url(#globe-clip)" fill="none" stroke="#d8b56a">
        <!-- Latitude parallels -->
        <ellipse cx="250" cy="250" rx="190" ry="36" stroke-width="0.5" stroke-opacity="0.42"/>
        <ellipse cx="250" cy="250" rx="190" ry="86" stroke-width="0.45" stroke-opacity="0.3"/>
        <ellipse cx="250" cy="250" rx="190" ry="138" stroke-width="0.4" stroke-opacity="0.22"/>
        <ellipse cx="250" cy="180" rx="190" ry="36" stroke-width="0.35" stroke-opacity="0.16"/>
        <ellipse cx="250" cy="322" rx="190" ry="36" stroke-width="0.35" stroke-opacity="0.16"/>
        <!-- Longitude meridians -->
        <ellipse cx="250" cy="250" rx="190" ry="190" stroke-width="0.5" stroke-opacity="0.36"/>
        <ellipse cx="250" cy="250" rx="95" ry="190" stroke-width="0.45" stroke-opacity="0.3"/>
        <ellipse cx="250" cy="250" rx="48" ry="190" stroke-width="0.35" stroke-opacity="0.2"/>
        <ellipse cx="250" cy="250" rx="143" ry="190" stroke-width="0.38" stroke-opacity="0.26"/>
        <!-- Equator -->
        <line x1="60" y1="250" x2="440" y2="250" stroke-width="0.6" stroke-opacity="0.4"/>
        <!-- Prime meridian -->
        <line x1="250" y1="60" x2="250" y2="440" stroke-width="0.5" stroke-opacity="0.32"/>
      </g>

      <!-- Rim -->
      <circle cx="250" cy="250" r="190" fill="none" stroke="#d8b56a" stroke-width="0.8" stroke-opacity="0.28"/>

      <!-- Bulgaria marker (approx. 43°N 25°E on visible face) -->
      <g class="globe-marker">
        <circle cx="291" cy="208" r="3.5" fill="#d8b56a" opacity="0.9"/>
        <circle cx="291" cy="208" r="8" fill="none" stroke="#d8b56a" stroke-width="0.8" stroke-opacity="0.5"/>
        <circle cx="291" cy="208" r="14" fill="none" stroke="#d8b56a" stroke-width="0.4" stroke-opacity="0.25"/>
      </g>
    </svg>
  </div>

  <!-- The Question -->
  <div class="arrival-copy">
    <h1 class="arrival-title">
      <span class="arrival-line al-1">{h.line1}</span>
      <span class="arrival-line al-2">{h.line2} {h.line3}</span>
      <span class="arrival-line al-3">{h.question}</span>
    </h1>

    <a class="arrival-cta" href={`/${lang}#timeline`} aria-label={a.cta}>
      <span>{a.cta}</span>
      <svg class="arrival-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
        <path d="M12 4v16M5 13l7 7 7-7"/>
      </svg>
    </a>
  </div>

  <!-- Bottom veil fading into next section -->
  <div class="arrival-veil" aria-hidden="true"></div>
</section>
