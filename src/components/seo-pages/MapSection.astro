---
import type { Dict } from "../../i18n";

interface Props {
  dict: Dict;
  coordinates: { lat: number; lng: number };
  title: string;
}

const { dict, coordinates, title } = Astro.props;
const c = dict.seoPages.common;
---

<section class="section seo-map-section" aria-labelledby="map-heading">
  <div class="wrap seo-map-grid">
    <div class="section-intro reveal">
      <p class="eyebrow">{c.map}</p>
      <h2 id="map-heading">{title}</h2>
      <p class="lede">{c.mapLabel}</p>
    </div>
    <div class="seo-map-card reveal reveal-d1">
      <div class="seo-map-pin" aria-hidden="true">◎</div>
      <p>{coordinates.lat.toFixed(4)}, {coordinates.lng.toFixed(4)}</p>
    </div>
  </div>
</section>
