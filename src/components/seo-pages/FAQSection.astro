---
import type { Dict } from "../../i18n";
import type { LocalizedSeoCopy } from "../../data/seoPages";

interface Props {
  dict: Dict;
  copy: LocalizedSeoCopy;
}

const { dict, copy } = Astro.props;
const c = dict.seoPages.common;
---

{copy.faq.length > 0 && (
  <section class="section" aria-labelledby="seo-faq-heading">
    <div class="wrap">
      <div class="section-intro reveal">
        <p class="eyebrow">{c.faq}</p>
        <h2 id="seo-faq-heading">{copy.title}</h2>
      </div>
      <div class="faq-list reveal reveal-d1" data-faq>
        {copy.faq.map((item) => (
          <article class="faq-item" data-faq-item>
            <button class="faq-q" type="button" data-faq-btn aria-expanded="false">
              <span>{item.q}</span>
              <span class="faq-chevron" aria-hidden="true">+</span>
            </button>
            <div class="faq-a">{item.a}</div>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
