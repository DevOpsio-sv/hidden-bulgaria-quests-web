---
import type { Dict } from "../i18n";
interface Props { dict: Dict; }
const { dict } = Astro.props;
const d = dict.timeline;
---

<section class="s-timeline" id="timeline" aria-labelledby="tl-heading">
  <div class="tl-intro wrap reveal">
    <p class="eyebrow">{d.eyebrow}</p>
    <h2 id="tl-heading">{d.heading}</h2>
    <p class="tl-intro-sub">{d.sub}</p>
  </div>

  <div class="tl-track wrap">
    {d.events.map((ev, i) => (
      <div class="tl-item reveal" data-tl-item>
        <div class="tli-year" aria-hidden="true">{ev.year}</div>
        <div class="tli-body">
          <p class="tli-label">{ev.shortName}</p>
          <h3 class="tli-headline">{ev.title}</h3>
          <p class="tli-body-text">{ev.body}</p>
        </div>
      </div>
    ))}
  </div>
</section>
