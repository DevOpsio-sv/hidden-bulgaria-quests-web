---
import type { Dict } from "../i18n";
interface Props { dict: Dict; lang: string; }
const { dict, lang } = Astro.props;
const d = dict.domains;

const atmoClasses = [
  "dc-stone", "dc-name", "dc-sea",
  "dc-kings", "dc-voice", "dc-cross",
];

const lures = [
  "Where the Danube met the empire.\nFortresses remember what history forgot.",
  "Pliska. Preslav. Tarnovo.\nThree capitals. One name that never fell.",
  "Ancient ports. Island monasteries.\nWhere the sea kept the secrets of the land.",
  "Tombs of gold. Rose fields.\nThe oldest memory in the land.",
  "Orpheus walked here.\nThe music still lives in the rocks.",
  "Roman ruins beneath the city.\nEvery layer tells a different story.",
];
---

<section class="s-domains" id="domains" aria-labelledby="domains-heading">
  <div class="domains-intro wrap">
    <p class="eyebrow">{d.eyebrow}</p>
    <h2 id="domains-heading">Every region hides a world.</h2>
  </div>

  <div class="domains-cinematic">
    {d.cards.map((card, i) => {
      const epochLabel = card.epoch === "before" ? d.epochBefore : d.epochAfter;
      const delay = i % 2 === 1 ? " reveal-d1" : "";
      return (
        <article class={`domain-cin ${atmoClasses[i]} reveal${delay}`}>
          <div class="dc-atmo" aria-hidden="true"></div>
          <div class="dc-content">
            <p class="dc-epoch">{epochLabel}</p>
            <h3 class="dc-title">{card.name}</h3>
            <p class="dc-region">{card.region}</p>
            <p class="dc-lure">{lures[i]}</p>
          </div>
        </article>
      );
    })}
  </div>
</section>
