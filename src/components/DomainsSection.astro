---
import type { Dict } from "../i18n";
interface Props { dict: Dict; lang: string; }
const { dict, lang } = Astro.props;
const d = dict.domains;
---

<section class="section" id="domains" aria-labelledby="domains-heading">
  <div class="wrap">
    <div class="section-intro reveal">
      <p class="eyebrow">{d.eyebrow}</p>
      <h2 id="domains-heading">{d.heading}</h2>
      <p class="lede">{d.lede}</p>
    </div>

    <div class="domains-grid">
      {d.cards.map((card, i) => {
        const delay = i % 3 === 1 ? "reveal-d1" : i % 3 === 2 ? "reveal-d2" : "";
        const routesDone = Math.round((card.progress / 100) * 3);
        const ctaLabel = card.status === "continue" ? d.continue : d.explore;
        const epochLabel = card.epoch === "before" ? d.epochBefore : d.epochAfter;
        return (
          <article class={`domain-card reveal ${delay}`}>
            <div class="domain-top">
              <div class="domain-emblem" aria-hidden="true">{card.emblem}</div>
              <span class="domain-epoch">{epochLabel}</span>
            </div>
            <div class="domain-body">
              <p class="domain-region">{card.region}</p>
              <h3 class="domain-name">{card.name}</h3>
              <p class="domain-key">{card.key}</p>
              <div
                class="domain-bar"
                role="progressbar"
                aria-valuenow={card.progress}
                aria-valuemin={0}
                aria-valuemax={100}
                aria-label={`${card.name} progress: ${card.progress}%`}
              >
                <div class="domain-fill" style={`width:${card.progress}%`}></div>
              </div>
              <p class="domain-progress-label">{routesDone} {d.routesOf}</p>
            </div>
            <div class="domain-footer">
              <span class="domain-cta">{ctaLabel}</span>
              <span class="domain-arrow" aria-hidden="true">→</span>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
