---
import { ViewTransitions } from "astro:transitions";
import type { Dict } from "../i18n";
import { SUPPORTED_LANGS } from "../i18n";
import LivingBackground from "../components/LivingBackground.astro";
import "../styles/global.css";

interface Props {
  dict: Dict;
  lang: string;
  canonicalPath?: string;
  seo?: {
    title?: string;
    description?: string;
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
    type?: string;
  };
  jsonLd?: unknown[];
}

const OG_LOCALE_MAP: Record<string, string> = {
  en: "en_US", bg: "bg_BG", de: "de_DE", fr: "fr_FR", es: "es_ES",
  it: "it_IT", ro: "ro_RO", tr: "tr_TR", el: "el_GR", hu: "hu_HU",
  zh: "zh_CN", ru: "ru_RU", ja: "ja_JP", sr: "sr_RS",
};

const SITE_ORIGIN = "https://unlockingbulgaria.com";
const DEFAULT_OG_IMAGE = `${SITE_ORIGIN}/og-image.png`;

const { dict, lang, canonicalPath = "", seo, jsonLd = [] } = Astro.props;
const canonical = `${SITE_ORIGIN}/${lang}${canonicalPath}`;
const metaTitle = seo?.title ?? dict.meta.title;
const metaDescription = seo?.description ?? dict.meta.description;
const ogTitle = seo?.ogTitle ?? seo?.title ?? dict.meta.ogTitle;
const ogDescription = seo?.ogDescription ?? seo?.description ?? dict.meta.ogDescription;
const ogImage = seo?.ogImage ?? DEFAULT_OG_IMAGE;
const ogLocale = OG_LOCALE_MAP[lang] ?? "en_US";
---

<!doctype html>
<html lang={lang} dir={lang === "ar" ? "rtl" : "ltr"}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#030610" />
  <meta name="robots" content="index, follow" />
  <ViewTransitions />

  <title>{metaTitle}</title>
  <meta name="description" content={metaDescription} />

  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/favicon.png" type="image/png" />
  <link rel="apple-touch-icon" href="/logo-icon.png" />

  <!-- Open Graph -->
  <meta property="og:type" content={seo?.type ?? "website"} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Unlocking Bulgaria" />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image" content={ogImage} />

  <!-- hreflang alternates -->
  {SUPPORTED_LANGS.map((l) => (
    <link rel="alternate" hreflang={l} href={`${SITE_ORIGIN}/${l}${canonicalPath}`} />
  ))}
  <link rel="alternate" hreflang="x-default" href={`${SITE_ORIGIN}/en${canonicalPath}`} />

  <!-- Fonts: preload as style so fetch is non-blocking; onload swaps rel to stylesheet -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@400;500;600&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@400;500;600&display=swap" /></noscript>

  <!-- Structured data -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Unlocking Bulgaria",
    "applicationCategory": "TravelApplication",
    "operatingSystem": "iOS, Android",
    "description": metaDescription,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
    "url": `${SITE_ORIGIN}/${lang}`
  })} />
  {jsonLd.map((schema) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
  <style is:global>
    html{
      max-width:100vw;
      overflow-x:hidden;
    }
    body{
      max-width:100vw;
      overflow-x:hidden;
    }
    main,
    section,
    .wrap{
      max-width:100%;
    }
    img,
    video,
    canvas,
    svg{
      max-width:100%;
    }
    ::view-transition{
      background:var(--void);
      max-width:100vw;
      overflow:hidden;
    }
    ::view-transition-group(root){
      animation-duration:.5s;
      animation-timing-function:ease-in-out;
      max-width:100vw;
      overflow:hidden;
    }
    ::view-transition-old(root){
      animation:ub-page-leave .5s ease-in-out both;
      max-width:100vw;
      overflow:hidden;
      transform-origin:left center;
    }
    ::view-transition-new(root){
      animation:ub-page-enter .5s ease-in-out both;
      animation-fill-mode:forwards;
      max-width:100vw;
      overflow:hidden;
      transform-origin:left center;
    }
    @keyframes ub-page-leave{
      0%{opacity:1;filter:brightness(1);transform:scaleX(1)}
      100%{opacity:0;filter:brightness(.75);transform:scaleX(0)}
    }
    @keyframes ub-page-enter{
      0%{opacity:0;filter:brightness(.75);transform:scaleX(0)}
      100%{opacity:1;filter:brightness(1);transform:scaleX(1)}
    }
    .ub-page-magic{
      inset:0;
      pointer-events:none;
      position:fixed;
      z-index:10000;
    }
    .shooting-stars-container{
      contain:strict;
      height:100vh;
      left:0;
      overflow:hidden;
      pointer-events:none;
      position:fixed;
      top:0;
      width:100vw;
      z-index:0;
    }
    .shooting-stars-container span{
      animation:magical-star-fall var(--star-duration,5s) ease-in-out var(--star-delay,0s) infinite;
      background:linear-gradient(90deg,rgba(255,255,255,.95) 0%,rgba(212,175,55,.9) 14%,rgba(212,175,55,.38) 48%,rgba(212,175,55,0) 100%);
      border-radius:999px;
      box-shadow:0 0 8px rgba(212,175,55,.38),0 0 18px rgba(245,226,168,.14);
      height:1px;
      opacity:0;
      position:absolute;
      left:var(--star-left,auto);
      right:var(--star-right,auto);
      top:var(--star-top,12vh);
      scale:var(--star-scale,1);
      transform:rotate(-45deg);
      transform-origin:left center;
      width:var(--star-width,42px);
      will-change:transform,opacity;
    }
    .shooting-stars-container span::before{
      background:#fff;
      border-radius:50%;
      box-shadow:0 0 10px 2px rgba(255,255,255,.8),0 0 18px 5px rgba(212,175,55,.3);
      content:"";
      height:var(--star-head,4px);
      left:-1px;
      position:absolute;
      top:50%;
      transform:translate(-50%,-50%);
      width:var(--star-head,4px);
    }
    .shooting-stars-container .star-1{--star-top:-5%;--star-left:30%;--star-width:42px;--star-head:3px;--star-duration:4.8s;--star-delay:0s;--star-scale:1}
    .shooting-stars-container .star-2{--star-top:-5%;--star-left:80%;--star-width:36px;--star-head:3px;--star-duration:5.8s;--star-delay:2s;--star-scale:.6}
    .shooting-stars-container .star-3{--star-top:20%;--star-right:-5%;--star-width:48px;--star-head:4px;--star-duration:4.2s;--star-delay:4s;--star-scale:1.2}
    .shooting-stars-container .star-4{--star-top:60%;--star-right:-5%;--star-width:32px;--star-head:3px;--star-duration:5.4s;--star-delay:7s;--star-scale:.75}
    .shooting-stars-container .star-5{--star-top:-10%;--star-left:120%;--star-width:44px;--star-head:3px;--star-duration:6s;--star-delay:9s;--star-scale:1.1}
    @keyframes magical-star-fall{
      0%{
        opacity:0;
        transform:rotate(-45deg) translateX(0);
      }
      10%{
        opacity:1;
      }
      90%{
        opacity:1;
      }
      100%{
        transform:rotate(-45deg) translateX(-120vh);
        opacity:0;
      }
    }
    @media(max-width:767px){
      ::view-transition-old(root){
        animation-name:ub-page-leave-mobile;
        transform-origin:center top;
      }
      ::view-transition-new(root){
        animation-name:ub-page-enter-mobile;
        transform-origin:center top;
      }
      @keyframes ub-page-leave-mobile{
        0%{opacity:1;filter:brightness(1);transform:scaleY(1)}
        100%{opacity:0;filter:brightness(.75);transform:scaleY(0)}
      }
      @keyframes ub-page-enter-mobile{
        0%{opacity:0;filter:brightness(.75);transform:scaleY(0)}
        100%{opacity:1;filter:brightness(1);transform:scaleY(1)}
      }
    }
    @media(max-width:760px){
      .wrap{
        padding-left:clamp(16px,5vw,24px);
        padding-right:clamp(16px,5vw,24px);
      }
      .section{
        padding-bottom:clamp(56px,12vw,88px);
        padding-top:clamp(56px,12vw,88px);
      }
      [class*="grid"],
      [class*="layout"]{
        min-width:0;
      }
    }
    @media(prefers-reduced-motion:reduce){
      ::view-transition-old(root),
      ::view-transition-new(root){
        animation:none;
      }
      .shooting-stars-container span{
        animation:none;
      }
    }
  </style>
</head>
<body>
  <LivingBackground />
  <div class="shooting-stars-container" aria-hidden="true">
    <span class="star-1"></span>
    <span class="star-2"></span>
    <span class="star-3"></span>
    <span class="star-4"></span>
    <span class="star-5"></span>
  </div>

  <a class="skip" href="#main">{dict.skipLink}</a>

  <slot />

  <!-- Header scroll state -->
  <script is:inline data-astro-rerun>
  (function(){
    var h=document.querySelector("[data-header]");
    if(!h)return;
    var u=function(){h.toggleAttribute("data-scrolled",window.scrollY>60)};
    u();window.addEventListener("scroll",u,{passive:true});
  })();
  </script>

  <!-- Book-flip transition sparks -->
  <script is:inline data-astro-rerun>
  (function(){
    if(window.__ubBookMagicInit)return;
    window.__ubBookMagicInit=true;
    if(!("startViewTransition" in document))return;
    if(window.matchMedia("(prefers-reduced-motion:reduce)").matches)return;

    function runBookMagic(){
      var canvas=document.createElement("canvas");
      var ctx=canvas.getContext("2d");
      if(!ctx)return;
      var dpr=Math.min(window.devicePixelRatio||1,2);
      var w=window.innerWidth;
      var h=window.innerHeight;
      var mobile=window.matchMedia("(max-width:700px)").matches;
      var originX=mobile?w/2:Math.max(18,w*.08);
      var originY=mobile?h*.78:h/2;
      var particles=[];
      var started=performance.now();
      var duration=850;

      canvas.className="ub-page-magic";
      canvas.width=Math.round(w*dpr);
      canvas.height=Math.round(h*dpr);
      canvas.style.width=w+"px";
      canvas.style.height=h+"px";
      ctx.scale(dpr,dpr);
      document.body.appendChild(canvas);

      for(var i=0;i<72;i++){
        var a=mobile?(-Math.PI/2+(Math.random()-.5)*1.25):((Math.random()-.5)*1.6);
        var speed=1.2+Math.random()*5.4;
        particles.push({
          x:originX+(Math.random()-.5)*18,
          y:originY+(Math.random()-.5)*(mobile?18:h*.38),
          vx:Math.cos(a)*speed+(mobile?(Math.random()-.5)*1.6:1.7+Math.random()*2.8),
          vy:Math.sin(a)*speed+(mobile?-(1.8+Math.random()*2.6):(Math.random()-.5)*2.1),
          r:.8+Math.random()*2.6,
          life:.55+Math.random()*.45,
          gold:Math.random()>.28
        });
      }

      function tick(now){
        var t=Math.min((now-started)/duration,1);
        ctx.clearRect(0,0,w,h);

        var mist=ctx.createRadialGradient(originX,originY,0,originX,originY,Math.max(w,h)*.58);
        mist.addColorStop(0,"rgba(216,181,106,"+(0.16*(1-t))+")");
        mist.addColorStop(.38,"rgba(245,226,168,"+(0.06*(1-t))+")");
        mist.addColorStop(1,"rgba(216,181,106,0)");
        ctx.fillStyle=mist;
        ctx.fillRect(0,0,w,h);

        particles.forEach(function(p){
          p.x+=p.vx;
          p.y+=p.vy;
          p.vx*=.985;
          p.vy*=.982;
          p.vy+=mobile?.012:.006;
          var alpha=Math.max(0,(1-t)*p.life);
          ctx.beginPath();
          ctx.fillStyle=p.gold?"rgba(232,200,120,"+alpha+")":"rgba(255,244,204,"+(alpha*.72)+")";
          ctx.shadowBlur=18;
          ctx.shadowColor="rgba(232,200,120,.55)";
          ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
          ctx.fill();
          ctx.shadowBlur=0;
        });

        if(t<1)requestAnimationFrame(tick);
        else canvas.remove();
      }

      requestAnimationFrame(tick);
    }

    document.addEventListener("astro:before-preparation",runBookMagic);
  })();
  </script>

  <!-- Mobile nav -->
  <script is:inline data-astro-rerun>
  (function(){
    var btn=document.querySelector("[data-menu-btn]");
    var nav=document.querySelector("[data-mobile-nav]");
    if(!btn||!nav)return;
    btn.addEventListener("click",function(){
      var o=nav.classList.toggle("open");
      btn.setAttribute("aria-expanded",String(o));
    });
    nav.addEventListener("click",function(e){
      if(e.target.tagName==="A"){nav.classList.remove("open");btn.setAttribute("aria-expanded","false");}
    });
    document.addEventListener("keydown",function(e){
      if(e.key==="Escape"&&nav.classList.contains("open")){
        nav.classList.remove("open");btn.setAttribute("aria-expanded","false");btn.focus();
      }
    });
  })();
  </script>

  <!-- Language overlay -->
  <script is:inline data-astro-rerun>
  (function(){
    var openBtns=document.querySelectorAll("[data-lang-btn],[data-lang-btn-mobile]");
    var overlay=document.querySelector("[data-lang-overlay]");
    var closeBtn=document.querySelector("[data-lang-close]");
    var lbls=document.querySelectorAll("[data-lang-lbl]");
    if(!openBtns.length||!overlay||!closeBtn)return;
    var labels={en:"EN",bg:"БГ",de:"DE",fr:"FR",es:"ES",it:"IT",ro:"RO",tr:"TR",el:"ΕΛ",hu:"HU",zh:"中文",ru:"РУ",ja:"JA",sr:"СР"};
    function open(){
      var mobileNav=document.querySelector("[data-mobile-nav]");
      var menuBtn=document.querySelector("[data-menu-btn]");
      if(mobileNav){mobileNav.classList.remove("open");}
      if(menuBtn){menuBtn.setAttribute("aria-expanded","false");}
      overlay.classList.add("open");
      openBtns.forEach(function(b){b.setAttribute("aria-expanded","true");});
      closeBtn.focus();
    }
    function close(){
      overlay.classList.remove("open");
      openBtns.forEach(function(b){b.setAttribute("aria-expanded","false");});
      var menuBtn=document.querySelector("[data-menu-btn]");
      var desktopBtn=document.querySelector("[data-lang-btn]");
      if(menuBtn&&getComputedStyle(menuBtn).display!=="none"){menuBtn.focus();}
      else if(desktopBtn){desktopBtn.focus();}
    }
    openBtns.forEach(function(btn){btn.addEventListener("click",open);});
    closeBtn.addEventListener("click",close);
    document.addEventListener("keydown",function(e){if(e.key==="Escape"&&overlay.classList.contains("open"))close();});
    overlay.querySelectorAll("[data-lang-pill]").forEach(function(p){
      p.addEventListener("click",function(){
        overlay.querySelectorAll("[data-lang-pill]").forEach(function(x){x.classList.remove("active");});
        p.classList.add("active");
        var lang=p.dataset.langPill;
        lbls.forEach(function(lbl){if(labels[lang])lbl.textContent=labels[lang];});
        document.documentElement.lang=lang;
        var seg=window.location.pathname.split("/").filter(Boolean);
        var known=["en","bg","de","fr","es","it","ro","tr","el","hu","zh","ru","ja","sr"];
        if(seg.length&&known.includes(seg[0]))seg[0]=lang;
        else seg.unshift(lang);
        window.location.pathname="/"+seg.join("/");
      });
    });
  })();
  </script>

  <!-- FAQ accordion -->
  <script is:inline data-astro-rerun>
  (function(){
    var list=document.querySelector("[data-faq]");
    if(!list)return;
    list.querySelectorAll("[data-faq-btn]").forEach(function(btn){
      btn.addEventListener("click",function(){
        var item=btn.closest("[data-faq-item]");
        var isOpen=item.classList.contains("open");
        list.querySelectorAll("[data-faq-item]").forEach(function(i){
          i.classList.remove("open");
          i.querySelector("[data-faq-btn]").setAttribute("aria-expanded","false");
        });
        if(!isOpen){item.classList.add("open");btn.setAttribute("aria-expanded","true");}
      });
    });
  })();
  </script>

  <!-- Scroll reveal -->
  <script is:inline data-astro-rerun>
  (function(){
    if(window.matchMedia("(prefers-reduced-motion:reduce)").matches){
      document.querySelectorAll(".reveal").forEach(function(e){e.classList.add("visible");});return;
    }
    var io=new IntersectionObserver(function(entries){
      entries.forEach(function(en){if(en.isIntersecting){en.target.classList.add("visible");io.unobserve(en.target);}});
    },{threshold:.1});
    document.querySelectorAll(".reveal").forEach(function(e){io.observe(e);});
  })();
  </script>

  <!-- Hero: pause video for reduced-motion; lightbox toggle -->
  <script is:inline data-astro-rerun>
  (function(){
    /* Pause hero background video for reduced-motion users */
    var bgVid=document.querySelector('.hero-video');
    if(bgVid&&window.matchMedia('(prefers-reduced-motion:reduce)').matches){
      bgVid.pause();
      bgVid.removeAttribute('autoplay');
    }

    /* Lightbox elements */
    var openBtn=document.querySelector('[data-lightbox-btn]');
    var lightbox=document.getElementById('hero-lightbox');
    var closeBtn=document.querySelector('[data-lightbox-close]');
    if(!openBtn||!lightbox)return;

    var lbVideo=lightbox.querySelector('.hero-lightbox-video');
    var lbAudio=lightbox.querySelector('.hero-lightbox-audio');

    function resetMedia(){
      if(lbVideo){lbVideo.pause();lbVideo.currentTime=0;}
      if(lbAudio){lbAudio.pause();lbAudio.currentTime=0;}
    }

    function startMedia(){
      /* Play video — ignore AbortError from rapid open/close */
      if(lbVideo){
        var vp=lbVideo.play();
        if(vp&&typeof vp.catch==='function')vp.catch(function(){});
      }
      /* Play audio in the same user-gesture tick */
      if(lbAudio){
        var ap=lbAudio.play();
        if(ap&&typeof ap.catch==='function')ap.catch(function(){});
      }
    }

    function openLb(){
      lightbox.removeAttribute('hidden');
      lightbox.focus();
      openBtn.setAttribute('aria-expanded','true');
      startMedia();
    }

    function closeLb(){
      lightbox.setAttribute('hidden','');
      openBtn.setAttribute('aria-expanded','false');
      openBtn.focus();
      resetMedia();
    }

    /* Audio ends last (12s) — video (10s) has already ended naturally;
       modal stays open, nothing extra needed on audio 'ended'. */

    /* Wire controls — user clicking the native video pause/play
       should also mirror the audio state */
    if(lbVideo){
      lbVideo.addEventListener('pause',function(){
        if(lbAudio&&!lbAudio.ended)lbAudio.pause();
      });
      lbVideo.addEventListener('play',function(){
        if(lbAudio&&!lbAudio.ended){
          var ap=lbAudio.play();
          if(ap&&typeof ap.catch==='function')ap.catch(function(){});
        }
      });
    }

    openBtn.addEventListener('click',openLb);
    if(closeBtn)closeBtn.addEventListener('click',closeLb);
    lightbox.addEventListener('click',function(e){if(e.target===lightbox)closeLb();});
    document.addEventListener('keydown',function(e){
      if(e.key==='Escape'&&!lightbox.hasAttribute('hidden'))closeLb();
    });
  })();
  </script>

  <!-- Scroll spine -->
  <script is:inline data-astro-rerun>
  (function(){
    var wrap=document.getElementById('spine-wrap');
    var fill=document.getElementById('spine-fill');
    if(!wrap||!fill||window.matchMedia('(prefers-reduced-motion:reduce)').matches)return;
    var h=wrap.offsetHeight;
    window.addEventListener('resize',function(){h=wrap.offsetHeight;},{passive:true});
    function update(){
      var r=wrap.getBoundingClientRect();
      var wh=window.innerHeight;
      var scrolled=Math.max(0,wh-r.top);
      var total=h+wh;
      var prog=Math.min(1,scrolled/total);
      fill.style.height=Math.round(prog*h)+'px';
      fill.classList.toggle('active',prog>0.02&&prog<0.99);
    }
    window.addEventListener('scroll',update,{passive:true});
    update();
  })();
  </script>

  <!-- Custom scanning-lens cursor (desktop / fine pointer) -->
  <script is:inline data-astro-rerun>
  (function(){
    if(!window.matchMedia('(pointer:fine)').matches)return;
    if(window.matchMedia('(prefers-reduced-motion:reduce)').matches)return;
    var lens=document.createElement('div');
    lens.className='cursor-lens';
    lens.setAttribute('aria-hidden','true');
    document.body.appendChild(lens);
    var mx=0,my=0,lx=0,ly=0,raf=0;
    function move(e){
      mx=e.clientX;my=e.clientY;
      if(!raf)raf=requestAnimationFrame(tick);
    }
    function tick(){
      lx+=(mx-lx)*.18;ly+=(my-ly)*.18;
      lens.style.transform='translate('+(lx-19)+'px,'+(ly-19)+'px)';
      lens.style.opacity='1';
      if(Math.abs(mx-lx)>.3||Math.abs(my-ly)>.3){
        raf=requestAnimationFrame(tick);
      }else{
        raf=0;
      }
    }
    document.addEventListener('mousemove',move,{passive:true});
    document.addEventListener('mouseleave',function(){
      lens.style.opacity='0';
      cancelAnimationFrame(raf);raf=0;
    });
  })();
  </script>

  <!-- Partner form -->
  <script is:inline data-astro-rerun>
  (function(){
    var form=document.querySelector("[data-partner-form]");
    var note=document.querySelector("[data-form-note]");
    if(!form)return;
    form.addEventListener("submit",function(e){
      e.preventDefault();
      var d=new FormData(form);
      var org=String(d.get("org")||"").trim();
      var email=String(d.get("email")||"").trim();
      var type=String(d.get("type")||"").trim();
      var region=String(d.get("region")||"").trim();
      var msg=String(d.get("message")||"").trim();
      var sub=encodeURIComponent("Partnership inquiry — "+(org||"Unlocking Bulgaria website"));
      var body=encodeURIComponent(["Organization: "+org,"Email: "+email,"Type: "+type,"Region: "+region,"","Partnership interest:",msg].join("\n"));
      window.location.href="mailto:partners@unlockingbulgaria.com?subject="+sub+"&body="+body;
      if(note)note.textContent="Opening your email client with the inquiry.";
    });
  })();
