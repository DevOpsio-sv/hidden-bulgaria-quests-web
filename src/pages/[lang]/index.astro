---
import { SUPPORTED_LANGS, getDict, type Lang } from "../../i18n";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import HeroSection from "../../components/HeroSection.astro";
import BandSection from "../../components/BandSection.astro";
import MemorySection from "../../components/MemorySection.astro";
import HowItWorksSection from "../../components/HowItWorksSection.astro";
import DomainsSection from "../../components/DomainsSection.astro";
import GuardianSightSection from "../../components/GuardianSightSection.astro";
import TimelineSection from "../../components/TimelineSection.astro";
import JourneySection from "../../components/JourneySection.astro";
import FeaturesSection from "../../components/FeaturesSection.astro";
import DownloadCTA from "../../components/DownloadCTA.astro";
import PartnersSection from "../../components/PartnersSection.astro";
import FAQSection from "../../components/FAQSection.astro";
import ContactSection from "../../components/ContactSection.astro";
import Footer from "../../components/Footer.astro";

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const dict = getDict(lang as Lang);
---

<Base dict={dict} lang={lang as string}>
  <Header dict={dict} lang={lang as string} />

  <main id="main" transition:name="main-content" transition:animate="slide">
    <HeroSection dict={dict} lang={lang as string} />
    <BandSection dict={dict} />
    <MemorySection dict={dict} />

    <!-- Scroll spine wraps the narrative descent: HIW → Timeline → Journey -->
    <div class="scroll-spine-wrap" id="spine-wrap">
      <div class="scroll-spine-fill" id="spine-fill" aria-hidden="true"></div>
      <HowItWorksSection dict={dict} />
      <DomainsSection dict={dict} lang={lang as string} />
      <GuardianSightSection dict={dict} lang={lang as string} />
      <TimelineSection dict={dict} />
      <JourneySection dict={dict} />
    </div>

    <FeaturesSection dict={dict} />
    <DownloadCTA dict={dict} />
    <hr class="gold-rule" />
    <PartnersSection dict={dict} />
    <hr class="gold-rule" />
    <FAQSection dict={dict} />
    <hr class="gold-rule" />
    <ContactSection dict={dict} />
  </main>

  <Footer dict={dict} lang={lang as string} />
</Base>
